{
  "name": "rex-booking-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -k -n BE,FE -c yellow,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run",
    "dev:frontend": "npm --prefix frontend run dev",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "deploy:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "deploy:down": "docker compose -f docker-compose.prod.yml down",
    "deploy:logs": "docker compose -f docker-compose.prod.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
